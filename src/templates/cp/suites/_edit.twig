{% extends '_layouts/cp' %}
{% do view.registerAssetBundle('eventiva\\synmon\\assetbundles\\SynMonAssetBundle') %}
{# Load Sortable.js from CDN #}
{% js 'https://cdn.jsdelivr.net/npm/sortablejs@1.15.0/Sortable.min.js' %}

{% set selectedSubnavItem = 'suites' %}
{% set crumbs = [
    { label: 'SynMon', url: cpUrl('synmon') },
    { label: 'Test Suites', url: cpUrl('synmon/suites') },
] %}

{% block content %}

<form method="post" id="suite-form">
    {{ csrfInput() }}
    {% if suite %}<input type="hidden" name="suiteId" value="{{ suite.id }}">{% endif %}

    <div class="flex" style="gap:16px;flex-wrap:wrap">
        <div style="flex:1;min-width:280px">
            <div class="field">
                <div class="heading"><label>Name *</label></div>
                <div class="input"><input type="text" name="name" class="text fullwidth" required
                    value="{{ suite.name ?? '' }}" placeholder="z.B. Homepage Check"></div>
            </div>
            <div class="field">
                <div class="heading"><label>Beschreibung</label></div>
                <div class="input"><input type="text" name="description" class="text fullwidth"
                    value="{{ suite.description ?? '' }}"></div>
            </div>
            <div class="field">
                <div class="heading"><label>Zeitplan</label></div>

                {# Wochentage #}
                <div style="margin-bottom:10px">
                    <div style="font-size:12px;color:#666;margin-bottom:6px;font-weight:600">Wochentage</div>
                    <div style="display:flex;gap:6px;flex-wrap:wrap">
                        {% set days = ['Mo','Di','Mi','Do','Fr','Sa','So'] %}
                        {% set cronDays = suite.cronExpression is defined ? suite.cronExpression : '' %}
                        {% for i, day in days %}
                            <label style="display:flex;align-items:center;gap:4px;background:#f3f4f6;border:1px solid #d1d5db;border-radius:6px;padding:4px 10px;cursor:pointer;font-size:13px">
                                <input type="checkbox" class="cron-weekday" value="{{ i + 1 }}" style="margin:0">
                                {{ day }}
                            </label>
                        {% endfor %}
                        <label style="display:flex;align-items:center;gap:4px;background:#f3f4f6;border:1px solid #d1d5db;border-radius:6px;padding:4px 10px;cursor:pointer;font-size:13px">
                            <input type="checkbox" id="cron-every-day" style="margin:0">
                            Täglich
                        </label>
                    </div>
                </div>

                {# Feste Monatstage #}
                <div style="margin-bottom:10px">
                    <div style="font-size:12px;color:#666;margin-bottom:6px;font-weight:600">Feste Tage im Monat <small style="font-weight:400">(optional, kombinierbar mit Wochentagen)</small></div>
                    <div style="display:flex;gap:4px;flex-wrap:wrap">
                        {% for d in 1..31 %}
                            <label style="display:flex;align-items:center;justify-content:center;width:32px;height:32px;background:#f3f4f6;border:1px solid #d1d5db;border-radius:4px;cursor:pointer;font-size:12px">
                                <input type="checkbox" class="cron-monthday" value="{{ d }}" style="display:none">
                                {{ d }}
                            </label>
                        {% endfor %}
                    </div>
                </div>

                {# Uhrzeiten #}
                <div style="margin-bottom:10px">
                    <div style="font-size:12px;color:#666;margin-bottom:6px;font-weight:600">Uhrzeiten</div>
                    <div id="cron-times-list" style="display:flex;flex-direction:column;gap:6px">
                        <div class="cron-time-entry" style="display:flex;gap:6px;align-items:center">
                            <input type="time" class="cron-time text" value="08:00" style="width:120px">
                            <button type="button" class="btn-remove-time btn small" style="padding:2px 8px">✕</button>
                        </div>
                    </div>
                    <button type="button" id="btn-add-time" class="btn small" style="margin-top:8px">+ Uhrzeit hinzufügen</button>
                </div>

                {# Cron Preview #}
                <div style="margin-bottom:4px">
                    <div style="font-size:12px;color:#666;margin-bottom:4px;font-weight:600">Cron Expression (generiert)</div>
                    <div style="display:flex;gap:8px;align-items:center">
                        <input type="text" name="cronExpression" id="cron-expression" class="text code fullwidth"
                            value="{{ suite.cronExpression ?? '0 8 * * *' }}" placeholder="0 8 * * *">
                        <button type="button" id="btn-cron-advanced" class="btn small" title="Manuell bearbeiten">✏️</button>
                    </div>
                    <div id="cron-preview-text" style="font-size:11px;color:#6b7280;margin-top:4px"></div>
                </div>
            </div>

            <div class="field">
                <div class="heading"><label>
                    <input type="checkbox" name="enabled" value="1" {{ (suite is null or suite.enabled) ? 'checked' : '' }}>
                    Aktiv
                </label></div>
            </div>
        </div>
        <div style="flex:1;min-width:280px">
            <div class="field">
                <div class="heading"><label>Benachrichtigung: E-Mail</label></div>
                <div class="input"><input type="email" name="notifyEmail" class="text fullwidth"
                    value="{{ suite.notifyEmail ?? '' }}" placeholder="admin@example.com"></div>
            </div>
            <div class="field">
                <div class="heading"><label>Webhook-URL</label></div>
                <div class="input"><input type="url" name="notifyWebhookUrl" class="text fullwidth"
                    value="{{ suite.notifyWebhookUrl ?? '' }}" placeholder="https://hooks.slack.com/..."></div>
            </div>
            <div class="field">
                <div class="heading"><label>
                    <input type="checkbox" name="notifyOnSuccess" value="1"
                        {{ suite.notifyOnSuccess ?? false ? 'checked' : '' }}>
                    Auch bei Erfolg benachrichtigen
                </label></div>
            </div>
        </div>
    </div>

    <hr>

    <h2>Test Steps</h2>

    <div id="step-list">
        {% for i, step in steps %}
            {% include 'synmon/cp/suites/_step-row' with { step: step, index: i, stepTypes: stepTypes } %}
        {% endfor %}
    </div>

    <div style="display:flex;gap:10px;margin:16px 0;align-items:center">
        <select id="new-step-type" class="select">
            {% for typeKey, typeConfig in stepTypes %}
                <option value="{{ typeKey }}">{{ typeConfig.label }}</option>
            {% endfor %}
        </select>
        <button type="button" id="btn-add-step" class="btn">+ Step hinzufügen</button>
    </div>

    <hr>
    <div style="display:flex;gap:10px">
        <button type="submit" formaction="{{ cpUrl('synmon/suites/save') }}" class="btn submit">Speichern</button>
        <a href="{{ cpUrl('synmon/suites') }}" class="btn">Abbrechen</a>
        {% if suite %}
            <button type="button" class="btn btn-run-suite" data-suite-id="{{ suite.id }}" style="margin-left:auto">▶ Jetzt testen</button>
        {% endif %}
    </div>
</form>

{% endblock %}
