{% extends '_layouts/cp' %}
{% do view.registerAssetBundle('eventiva\\synmon\\assetbundles\\SynMonAssetBundle') %}

{% set selectedSubnavItem = 'runs' %}
{% set crumbs = [
    { label: 'SynMon', url: cpUrl('synmon') },
    { label: 'Run History', url: cpUrl('synmon/runs') },
] %}

{% block content %}

<div style="display:flex;gap:16px;margin-bottom:24px;flex-wrap:wrap;align-items:center">
    <div>
        <strong>Suite:</strong> <a href="{{ cpUrl('synmon/suites/' ~ run.suiteId) }}">{{ run.suiteName }}</a>
    </div>
    <div>
        <strong>Status:</strong>
        <span class="synmon-status-badge synmon-status-{{ run.status }}">{{ run.status }}</span>
    </div>
    <div><strong>Dauer:</strong> {{ run.durationMs ? (run.durationMs / 1000)|round(2) ~ 's' : '—' }}</div>
    <div><strong>Trigger:</strong> {{ run.trigger }}</div>
    <div><strong>Node:</strong> {{ run.nodeVersion ?? '—' }}</div>
    <div><strong>Playwright:</strong> {{ run.playwrightVersion ?? '—' }}</div>
    <div><strong>Datum:</strong> {{ run.dateCreated|date('d.m.Y H:i:s') }}</div>
</div>

{% if run.errorMessage %}
<div class="synmon-playwright-setup" style="background:#f8d7da;border-color:#dc3545;margin-bottom:20px">
    <strong>Fehlermeldung:</strong>
    <code style="color:#dc3545">{{ run.errorMessage }}</code>
</div>
{% endif %}

{# Check if screenshots exist for this run #}
{% set hasScreenshots = run.stepLogs|filter(l => l.screenshotUrl)|length > 0 %}

{% if hasScreenshots %}
<div id="synmon-screenshot-viewer" style="margin-bottom:24px;background:#1e293b;border-radius:8px;overflow:hidden">
    <div style="padding:8px 16px;background:#0f172a;display:flex;gap:12px;align-items:center">
        <span style="color:#94a3b8;font-size:12px">Screenshot-Vorschau</span>
        <span id="detail-step-label" style="color:#e2e8f0;font-size:12px"></span>
    </div>
    <div style="text-align:center;padding:8px;min-height:200px;display:flex;align-items:center;justify-content:center">
        <img id="detail-screenshot-img" src="" alt="Screenshot"
            style="max-width:100%;max-height:480px;border-radius:4px;display:none">
        <span id="detail-screenshot-placeholder" style="color:#475569;font-size:13px">Step auswählen um Screenshot anzuzeigen</span>
    </div>
</div>
{% endif %}

<h2>Step-für-Schritt Log</h2>

{% if run.stepLogs|length == 0 %}
<p style="color:#999">Keine Step-Logs vorhanden.</p>
{% else %}
{% for log in run.stepLogs %}
<div class="synmon-step-log-row {{ log.status }}"
    {% if log.screenshotUrl %}
    style="cursor:pointer"
    data-screenshot="{{ log.screenshotUrl }}"
    data-step-label="Step {{ loop.index }}: {{ log.type }}{% if log.selector %} {{ log.selector }}{% endif %}"
    onclick="synmonShowDetailScreenshot(this)"
    title="Klicken für Screenshot"
    {% endif %}>
    <div style="display:flex;gap:12px;align-items:center">
        <span class="synmon-status-badge synmon-status-{{ log.status }}">{{ log.status }}</span>
        <strong>{{ log.type }}</strong>
        {% if log.selector %}<code style="font-size:12px">{{ log.selector }}</code>{% endif %}
        {% if log.value %}<span style="color:#666">→ {{ log.value }}</span>{% endif %}
        {% if log.description %}<span style="color:#999;font-size:12px;margin-left:4px">// {{ log.description }}</span>{% endif %}
        <span style="margin-left:auto;display:flex;gap:8px;align-items:center">
            {% if log.screenshotUrl %}
                <span style="font-size:11px;color:#3b82f6">📷</span>
            {% endif %}
            <span style="color:#999;font-size:12px">{{ log.durationMs ? log.durationMs ~ 'ms' : '' }}</span>
        </span>
    </div>
    {% if log.errorMessage %}
    <div class="synmon-error-msg">{{ log.errorMessage }}</div>
    {% endif %}
    {% if log.consoleOutput %}
    <details style="margin-top:6px">
        <summary style="font-size:12px;color:#666;cursor:pointer">Console Output</summary>
        <pre style="font-size:11px;background:#f8f9fa;padding:8px;border-radius:4px;margin-top:4px;white-space:pre-wrap">{{ log.consoleOutput }}</pre>
    </details>
    {% endif %}
</div>
{% endfor %}
{% endif %}

<div style="margin-top:24px;display:flex;gap:8px;flex-wrap:wrap;align-items:center">
    <a href="{{ cpUrl('synmon/runs') }}" class="btn">← Zurück zur Liste</a>
    <a href="{{ cpUrl('synmon/suites/' ~ run.suiteId ~ '/live') }}" class="btn">🎬 Live erneut testen</a>
    <form method="post" style="display:inline" onsubmit="return confirm('Run löschen?')">
        {{ csrfInput() }}
        <input type="hidden" name="runId" value="{{ run.id }}">
        <button type="submit" formaction="{{ cpUrl('synmon/runs/delete') }}" class="btn">Löschen</button>
    </form>
</div>

{% if hasScreenshots %}
{% js %}
function synmonShowDetailScreenshot(row) {
    var url   = row.getAttribute('data-screenshot');
    var label = row.getAttribute('data-step-label');
    var img   = document.getElementById('detail-screenshot-img');
    var ph    = document.getElementById('detail-screenshot-placeholder');
    var lbl   = document.getElementById('detail-step-label');

    // Toggle deselect if same row clicked again
    if (img.src === url && img.style.display !== 'none') {
        img.style.display = 'none';
        ph.style.display  = 'block';
        lbl.textContent   = '';
        return;
    }

    img.style.display = 'none';
    ph.style.display  = 'block';
    lbl.textContent   = label;

    img.onload = function () {
        img.style.display = 'block';
        ph.style.display  = 'none';
    };
    img.src = url;
}
{% endjs %}
{% endif %}

{% endblock %}
